    subsystem = {
        name = "icon"             # 子系统名称标识符（在脚本中引用）
        max_amount = 1            # 最大粒子数量（同时只存在1个粒子）
        slave_particles = 0       # 从属粒子数量（0表示无次级粒子）
        sort = "depth"            # 渲染排序方式（按深度缓冲排序）
        emitter_type = "point"    # 发射器类型（单点发射）
        invert = no               # 不反转粒子法线方向
        trail = no                # 非拖尾型粒子
        local_space = yes         # 使用局部坐标系（随父物体移动）
        billboard = no            # 禁用始终面向相机（使用固定方向）
        hide = no                # 初始可见（不隐藏）
        # 纹理配置
        texture = {
            file = "gfx/particles/EX_bong/fazhen2.dds"  # 粒子贴图路径
            x = 1                 # UV坐标X轴平铺次数
            y = 1                 # UV坐标Y轴平铺次数
            shader = "ParticleAdditive"  # 渲染着色器（叠加混合模式）
        }
        # 粒子颜色配置
        color = {
            x = 255.000, color_r1  # 红色通道（绑定到动画变量color_r1）
            y = 255.000, color_g1  # 绿色通道（绑定到动画变量color_g1）
            z = 255.000, color_b1  # 蓝色通道（绑定到动画变量color_b1）
            alpha = 200.000        # 固定透明度（200/255≈78%不透明）
        }
        # 发射器位置偏移（局部坐标系）
        position = {
            x = 100.000             # X轴偏移量
            y = -250.000          # Y轴偏移量（向下150单位）
            z = 0.000             # Z轴偏移量
        }
        start = 0.000             # 起始时间（0秒立即开始）
        duration = -1.000         # 持续时间（-1表示永久持续）
        emitter_yaw = { 0.000 0.000 }   # 发射器偏航角范围（固定0°）
        emitter_pitch = { 0.000 0.000 } # 发射器俯仰角范围（固定0°）
        velocity_pitch = 45.000   # 粒子初始俯仰角（90°=垂直向下）
        velocity_yaw = 0.000      # 粒子初始偏航角（0°=正前方向）
        velocity = 0.000          # 粒子初始速度（0=静止）
        life = 90.00              # 粒子生命周期（90秒）
        emission = 10.000         # 发射间隔（每10秒发射1个粒子）
        size = 200.000, pulse     # 基础尺寸340单位，启用脉动效果（尺寸变化）
        particle_pitch = 0.000   # 粒子初始旋转俯仰角（90°=水平放置）
        rotation = 0.000          # 初始旋转角度（0°）
        rotation_speed = 5.000    # 旋转速度（5度/秒）
    }
    subsystem = {
        name = "icon"
        max_amount = 1
        slave_particles = 0
        sort = "depth"
        emitter_type = "point"
        invert = no
        trail = no
        local_space = yes
